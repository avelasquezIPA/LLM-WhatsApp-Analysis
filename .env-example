# Set path to Stata executable or binary
# Windows
STATA_CMD='C:\Program Files\Stata18\StataSE-64.exe'
# macOS
# STATA_CMD='/Applications/Stata/StataSE.app/Contents/MacOS/StataSE'
# Linux or WSL
# STATA_CMD='/usr/local/stata18/stata-se'
# Stata edition: 'be' (Basic), 'se' (Standard), or 'mp' (Multiprocessor)
STATA_EDITION='se'
# Stata execution mode for batch processing
# Windows: /e (execute without interaction), /q (suppress splash screen)
# Unix/Linux/macOS: -b (batch mode), -q (quiet)
STATA_MODE='/e /q'
